#!/bin/bash

# Usage: ./system_age_pretty.sh [-s]
# -s : silent mode (omit "System age:" prefix)

silent=false

while getopts ":s" opt; do
  case $opt in
    s) silent=true ;;
    \?)
      echo "Usage: $0 [-s]" >&2
      exit 1
      ;;
  esac
done

# Get filesystem birth date of root (/)
birth_date=$(stat -c %w /)

if [ "$birth_date" = "-" ]; then
  echo "Birth time not supported on this filesystem."
  exit 1
fi

# Normalize dates
birth=$(date -d "$birth_date" +%Y-%m-%d)
now=$(date +%Y-%m-%d)

# Calculate components using calendar logic
years=$(date -d "$now" +%Y)
birth_year=$(date -d "$birth" +%Y)

months=$(date -d "$now" +%m)
birth_month=$(date -d "$birth" +%m)

days=$(date -d "$now" +%d)
birth_day=$(date -d "$birth" +%d)

y=$((years - birth_year))
m=$((months - birth_month))
d=$((days - birth_day))

# Normalize negatives
if (( d < 0 )); then
  m=$((m - 1))
  d=$((d + $(date -d "$now -$(date -d "$now" +%d) days" +%d)))
fi

if (( m < 0 )); then
  y=$((y - 1))
  m=$((m + 12))
fi

age_string="${y} years, ${m} months, ${d} days"

if $silent; then
  echo "$age_string"
else
  echo "System age: $age_string"
fi
